# ─────────────────────────────────────────────────────────
# TalentTune-AI — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ── Optional: Enhances GitHub project matching ────────────
# Get at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN_HERE

# ── App Config ────────────────────────────────────────────
MAX_RESUME_SIZE_MB=10
DEFAULT_TARGET_ATS_SCORE=85
RATE_LIMIT_PER_MINUTE=10

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# ── Optional: Redis for rate limiting (production) ────────
# REDIS_URL=redis://localhost:6379/0
